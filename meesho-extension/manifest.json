{
  "manifest_version": 3,
  "name": "Meesho Seller Tools",
  "version": "2.1",
  "description": "Best Seller Finder + Keyword Research & SEO Optimizer for Meesho sellers.",
  "permissions": ["activeTab", "scripting", "sidePanel"],
  "host_permissions": ["https://www.meesho.com/*"],
  "action": {
    "default_icon": {
      "48": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
